{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Kestrel": {
    "EndpointDefaults": {
      "Protocols": "Http1AndHttp2"
    }
  },
  "AllowedHosts": "*",
  "AppSettings": {
    "Auth:": {},
    "Platform": {
      "__comment__": "Use the format provider:subject to specify each admin. `dotnet user-secrets set --project src/backend/Zeeq.Runtime.Server AppSettings:Platform:SystemAdminSubjects:0 provider:subject`",
      "SystemAdminSubjects": []
    },
    "Cache": {
      "Provider": "Postgres"
    },
    "Documents": {
      "LibraryExportSigningKey": ""
    }
  },
  "ZeeqMessaging": {
    "Provider": "Postgres"
  }
}
