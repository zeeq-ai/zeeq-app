{
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://+:8080",
        "Protocols": "Http2"
      }
    }
  },
  "AppSettings": {
    "Http": {
      "ApiBaseUri": "https://app.zeeq.ai",
      "FrontendBaseUri": "https://app.zeeq.ai/web",
      "AllowedCorsOrigins": [
        "https://app.zeeq.ai"
      ]
    },
    "Platform": {
      "__comment__": "Use the format provider:subject to specify each admin.",
      "SystemAdminSubjects": []
    },
    "Database": {
      "ConnectionString": "gcloud secrets create AppSettings__Database__ConnectionString"
    },
    "Auth": {
      "Issuer": "https://app.zeeq.ai",
      "Resource": "https://app.zeeq.ai/mcp",
      "FrontendBaseUri": "https://app.zeeq.ai/web",
      "AccessTokenFormat": "SignedJwt",
      "UserTokenDefaultLifetimeDays": 90,
      "UserTokenMaxLifetimeDays": 365,
      "DynamicClientRegistration": {
        "AllowedLoopbackHosts": [
          "localhost",
          "127.0.0.1",
          "[::1]"
        ],
        "AllowedStaticRedirectUris": [
          "cursor://anysphere.cursor-mcp/oauth/callback"
        ]
      },
      "Providers": [
        {
          "Name": "google",
          "DisplayName": "Google",
          "ClientId": "762440298446-cq83aq8jntmldvacd98c8n42ct9h8ui7.apps.googleusercontent.com",
          "ClientSecret": "gcloud secrets create AppSettings__Auth__Providers__0__ClientSecret",
          "IssuerUri": "https://accounts.google.com",
          "ServerCallbackUri": "https://app.zeeq.ai/auth/callback/google",
          "Scopes": [
            "openid",
            "profile",
            "email"
          ]
        },
        {
          "Name": "github",
          "DisplayName": "GitHub",
          "ClientId": "Ov23liueMtqzXmqHZ2wV",
          "ClientSecret": "gcloud secrets create AppSettings__Auth__Providers__1__ClientSecret",
          "IssuerUri": "https://github.com/login/oauth",
          "ServerCallbackUri": "https://app.zeeq.ai/auth/callback/github",
          "Scopes": [
            "user:email"
          ],
          "UserInfoEndpoint": "https://api.github.com/user"
        }
      ]
    },
    "GitHub": {
      "__comment__": "These are development specific settings",
      "AlwaysUseGhTokenForSync": false,
      "AppId": "4316328",
      "ClientId": "Iv23liIXrxI3FWl8kZwn",
      "PrivateKeyPem": "gcloud secrets create AppSettings__GitHub__PrivateKeyPem",
      "AppSlug": "zeeq-ai",
      "WebhookSecret": "gcloud secrets create AppSettings__GitHub__WebhookSecret"
    },
    "CodeReview": {
      "__comment__": "Review budget and secure review-request link settings. Store the real encryption key in user secrets for local development.",
      "AgentIdentity": "zeeq-code-review-agent",
      "ReviewRequestLinkEncryptionKey": "gcloud secrets create AppSettings__CodeReview__ReviewRequestLinkEncryptionKey",
      "ReviewRequestLinkValidityDays": 7,
      "DefaultReviewBudget": 20
    },
    "Llm": {
      "__comment__": "Store the real Fireworks API key in user secrets/Secret Manager: dotnet user-secrets set --project src/backend/Zeeq.Runtime.Server AppSettings:Llm:Models:Fast:ApiKey <fireworks-key>",
      "EncryptionProvider": "cloud-kms",
      "GoogleKmsKeyName": "projects/zeeq-mcp-prod/locations/us-central1/keyRings/zeeq-runtime/cryptoKeys/zeeq-llm-secrets",
      "DataProtectionKeyRingPath": ".secrets/data-protection-keys",
      "Models": {
        "Fast": {
          "Provider": "Fireworks",
          "Model": "accounts/fireworks/models/deepseek-v4-flash",
          "ApiKey": "gcloud secrets create AppSettings__Llm__Models__Fast__ApiKey",
          "Endpoint": "https://api.fireworks.ai/inference/v1"
        },
        "High": {
          "Provider": "Fireworks",
          "Model": "accounts/fireworks/models/deepseek-v4-pro",
          "ApiKey": "",
          "Endpoint": "https://api.fireworks.ai/inference/v1"
        },
        "Max": {
          "Provider": "Fireworks",
          "Model": "accounts/fireworks/models/glm-5p2",
          "ApiKey": "",
          "Endpoint": "https://api.fireworks.ai/inference/v1"
        }
      },
      "Embeddings": {
        "Enabled": true,
        "ApiKey": "gcloud secrets create AppSettings__Llm__Embeddings__ApiKey"
      }
    },
    "Cache": {
      "Provider": "Postgres",
      "SchemaName": "cache",
      "TableName": "hybrid_cache",
      "CreateIfNotExists": true,
      "UseWAL": false,
      "ExpiredItemsDeletionInterval": "00:30:00",
      "DefaultSlidingExpiration": "00:20:00",
      "DefaultEntryExpiration": "00:10:00",
      "LocalCacheExpiration": "00:02:00",
      "MaximumPayloadBytes": 1048576,
      "MaximumKeyLength": 1024
    }
  },
  "ZeeqMessaging": {
    "Provider": "GcpPubSub",
    "GcpPubSub": {
      "MissingChannelPolicy": "Validate"
    },
    "TenantBuckets": {
      "PriorityBucketCount": 18,
      "DefaultBucketCount": 12,
      "LowBucketCount": 6
    }
  }
}
