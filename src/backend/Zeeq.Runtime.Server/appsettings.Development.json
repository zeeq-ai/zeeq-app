{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AppSettings": {
    "Http": {
      "ApiBaseUri": "http://zeeq-api.localhost:8095",
      "FrontendBaseUri": "http://zeeq-web.localhost:8095",
      "AllowedCorsOrigins": [
        "http://zeeq-inspector.localhost:8095"
      ]
    },
    "Platform": {
      "__comment__": "Use the format provider:subject to specify each admin. `dotnet user-secrets set --project src/backend/Zeeq.Runtime.Server AppSettings:Platform:SystemAdminSubjects:0 provider:subject`",
      "SystemAdminSubjects": []
    },
    "Auth": {
      "Issuer": "http://zeeq-web.localhost:8095",
      "Resource": "http://zeeq-web.localhost:8095/mcp",
      "FrontendBaseUri": "http://zeeq-web.localhost:8095",
      "MockProviderIssuer": "http://localhost:9321",
      "MockProviderName": "mock",
      "MockClientId": "mcp-openiddict-local",
      "MockCallbackUri": "http://localhost:8096/auth/callback/mock",
      "AccessTokenFormat": "SignedJwt",
      "UserTokenDefaultLifetimeDays": 90,
      "UserTokenMaxLifetimeDays": 365,
      "DynamicClientRegistration": {
        "AllowedLoopbackHosts": [
          "localhost",
          "127.0.0.1",
          "[::1]"
        ],
        "AllowedStaticRedirectUris": [
          "cursor://anysphere.cursor-mcp/oauth/callback",
          "http://zeeq-inspector.localhost:8095/oauth/callback",
          "http://zeeq-inspector.localhost:8095/oauth/callback/debug"
        ]
      },
      "Providers": [
        {
          "Name": "google",
          "DisplayName": "Google",
          "ClientId": "762440298446-i2eh4seuqaivtv58ksbscjl67cvmeu1d.apps.googleusercontent.com",
          "ClientSecret": "dotnet user-secrets set --project src/backend/Zeeq.Runtime.Server AppSettings:Auth:Providers:0:ClientSecret secret-value",
          "IssuerUri": "https://accounts.google.com",
          "ServerCallbackUri": "http://localhost:8096/auth/callback/google",
          "Scopes": [
            "openid",
            "profile",
            "email"
          ]
        },
        {
          "Name": "github",
          "DisplayName": "GitHub",
          "ClientId": "Ov23liueMtqzXmqHZ2wV",
          "ClientSecret": "dotnet user-secrets set --project src/backend/Zeeq.Runtime.Server AppSettings:Auth:Providers:1:ClientSecret secret-value",
          "IssuerUri": "https://github.com/login/oauth",
          "ServerCallbackUri": "http://localhost:8096/auth/callback/github",
          "Scopes": [
            "user:email"
          ],
          "UserInfoEndpoint": "https://api.github.com/user"
        }
      ]
    },
    "GitHub": {
      "__comment__": "These are development specific settings",
      "AlwaysUseGhTokenForSync": false,
      "AppId": "4318001",
      "ClientId": "Iv23lit7kEPJOpfhixLQ",
      "PrivateKeyPem": "dotnet user-secrets set --project src/backend/Zeeq.Runtime.Server AppSettings:GitHub:PrivateKeyPem secret-value",
      "AppSlug": "zeeq-ai-dev",
      "WebhookSecret": "dotnet user-secrets set --project src/backend/Zeeq.Runtime.Server AppSettings:GitHub:WebhookSecret secret-value"
    },
    "CodeReview": {
      "__comment__": "Review budget and secure review-request link settings. Store the real encryption key in user secrets for local development.",
      "AgentIdentity": "zeeq-code-review-agent",
      "ReviewRequestLinkEncryptionKey": "dotnet user-secrets set --project src/backend/Zeeq.Runtime.Server AppSettings:CodeReview:ReviewRequestLinkEncryptionKey secret-value",
      "ReviewRequestLinkValidityDays": 7,
      "DefaultReviewBudget": 20
    },
    "Llm": {
      "__comment__": "Store the real Fireworks API key in user secrets/Secret Manager: dotnet user-secrets set --project src/backend/Zeeq.Runtime.Server AppSettings:Llm:Models:Fast:ApiKey <fireworks-key>",
      "EncryptionProvider": "data-protection",
      "DataProtectionKeyRingPath": ".secrets/data-protection-keys",
      "Models": {
        "Fast": {
          "Provider": "Fireworks",
          "Model": "accounts/fireworks/models/glm-5p2",
          "Endpoint": "https://api.fireworks.ai/inference/v1"
        },
        "High": {
          "Provider": "Fireworks",
          "Model": "accounts/fireworks/models/glm-5p2",
          "Endpoint": "https://api.fireworks.ai/inference/v1"
        },
        "Max": {
          "Provider": "Fireworks",
          "Model": "accounts/fireworks/models/glm-5p2",
          "Endpoint": "https://api.fireworks.ai/inference/v1"
        }
      },
      "Embeddings": {
        "Enabled": true,
        "ApiKey": "dotnet user-secrets set --project src/backend/Zeeq.Runtime.Server AppSettings:Llm:Embeddings:ApiKey secret-value"
      }
    },
    "Cache": {
      "Provider": "Postgres",
      "SchemaName": "cache",
      "TableName": "hybrid_cache",
      "CreateIfNotExists": true,
      "UseWAL": false,
      "ExpiredItemsDeletionInterval": "00:30:00",
      "DefaultSlidingExpiration": "00:20:00",
      "DefaultEntryExpiration": "00:10:00",
      "LocalCacheExpiration": "00:02:00",
      "MaximumPayloadBytes": 1048576,
      "MaximumKeyLength": 1024
    }
  },
  "ZeeqMessaging": {
    "__comment__": "Postgres is suitable for local testing and single-server deployments, but larger scale will exhaust connection. Use GcpPubSub instead.",
    "Provider": "GcpPubSub",
    "GcpPubSub": {
      "MissingChannelPolicy": "Validate"
    }
  }
}
