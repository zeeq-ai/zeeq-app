{
  "mcpServers": {
    "aspire": {
      "type": "stdio",
      "command": "aspire",
      "args": [
        "agent",
        "mcp"
      ],
      "env": {}
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "@playwright/mcp@latest",
        "--extension"
      ],
      "env": {}
    },
    "glider": {
      "type": "http",
      "url": "http://localhost:5051/mcp"
    },
    "nuxtui": {
      "type": "http",
      "url": "https://ui.nuxt.com/mcp"
    },
    "zeeq": {
      "type": "http",
      "url": "https://app.zeeq.ai/mcp",
      "timeout": 120000
    },
    "local-dev-only-zeeq": {
      "type": "http",
      "url": "http://zeeq-web.localhost:8095/mcp",
      "timeout": 180000
    }
  }
}
